    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "cookies-next": "^6.1.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.20",
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.6.0",
